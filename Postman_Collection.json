        {
          "name": "Submit Admission",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camp_id\": 1,\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"age\": 30,\n  \"skills\": [\"Medical\", \"First Aid\"],\n  \"health_status\": \"Good\",\n  \"reason_to_join\": \"I'm a doctor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/admissions/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "admissions", "submit"]
            }
          }
        },
        {
          "name": "Get Pending Admissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/ai/admissions/pending?campId={{campId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "admissions", "pending"],
              "query": [
                {
                  "key": "campId",
                  "value": "{{campId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Track Admission",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/ai/admissions/track/:code",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "admissions", "track", ":code"],
              "variable": [
                {
                  "key": "code",
                  "value": "ADM-123456"
                }
              ]
            }
          }
        },
        {
          "name": "Review Admission",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"ACCEPT\",\n  \"notes\": \"Approved - medical skills needed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/admissions/:id/review",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "admissions", ":id", "review"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    },
