# App
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=gestion_del_fin

# JWT - Sesión expira en 20 minutos (requerimiento del proyecto)
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=20m
JWT_REFRESH_EXPIRES_IN=7d

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Rate Limiting (ThrottlerModule)
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# CSRF Protection - orígenes del frontend permitidos (separados por coma)
# Agregar todos los puertos donde corra el frontend
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Request Size Limits - tamaño máximo del body (ej: 500kb, 1mb, 5mb)
MAX_REQUEST_SIZE=1mb

# Cloudinary - Servicio de almacenamiento de imágenes
# Crear cuenta en: https://cloudinary.com/users/register/free
# Obtener credenciales en: Dashboard > Settings > Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
