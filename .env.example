# App
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=gestion_del_fin

# JWT - Sesión expira en 20 minutos (requerimiento del proyecto)
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=20m

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Rate Limiting (ThrottlerModule)
THROTTLE_TTL=60000
THROTTLE_LIMIT=10 
